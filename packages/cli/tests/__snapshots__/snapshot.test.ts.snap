  min-height: 100px;
  white-space: pre-wrap;
}

/* Audio: controls */
.controls { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
.controls button {
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: 6px;
  cursor: pointer;
