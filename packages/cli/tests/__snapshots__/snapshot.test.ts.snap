}

/* Depth estimation: canvas output */
.depth-canvas {
  max-width: 100%;
  border-radius: var(--webai-radius);
  display: block;
}

/* NER: entity highlights */
.ner-output {
  background: var(--webai-surface);
  border: 1px solid var(--webai-border);
  border-radius: var(--webai-radius);
  padding: var(--webai-space-3);
