</head>
<body>
  <a href="#results" class="skip-link">Skip to results</a>

  <main>
    <h1>tts-model — Text to Speech</h1>

    <h2>Text to Speech</h2>

    <div class="tts-input">
      <label for="textInput">Enter text to synthesize</label>
      <textarea id="textInput" rows="4" aria-label="Text to synthesize">Hello, this is a test of text to speech.</textarea>
      <button id="synthesizeBtn" class="primary-btn" aria-label="Synthesize speech">Synthesize</button>
    </div>
  </main>

  <aside class="status-bar">
    <span id="status">tts-model · Loading...</span>
  </aside>

  <div class="footer">Generated by webai.js · tts-model · ONNX Runtime Web</div>

  <script type="module">
import * as ort from 'https://cdn.jsdelivr.net/npm/onnxruntime-web/dist/ort.min.mjs';

// --- Preprocessing ---


// --- Inference ---
/**
 * Create an ONNX Runtime Web inference session with backend selection.
 * The execution provider list determines hardware acceleration priority.
 */
async function createSession(modelPath) {
  // Backend auto-selection: try best available, fall through to WASM
  const providers = [];
  if ('ml' in navigator) {
    providers.push({ name: 'webnn', deviceType: 'npu' });
    providers.push({ name: 'webnn', deviceType: 'gpu' });
  }
  if (navigator.gpu) providers.push('webgpu');
  providers.push('wasm');

  const session = await ort.InferenceSession.create(modelPath, {
    executionProviders: providers,
  });

  // Log which backend was selected
  console.log('Inference session created');

  return session;
}

/**
 * Run inference on preprocessed input data.
 * Input: Float32Array from preprocessImage()
 * Output: Float32Array of raw model output (logits/scores)
 */
async function runInference(
  session,
  inputData
) {
  const tensor = new ort.Tensor('float32', inputData, [1, 100]);
  const feeds = { 'input': tensor };

  const results = await session.run(feeds);
  const outputName = session.outputNames[0];
  const output = results[outputName];

  return output.data;
}

/**
 * Get a display string for the active backend.
 * Used by the status bar: "yolov8n · 8ms · WebNN (NPU)"
 */
function getBackendLabel(session) {
  // ONNX Runtime Web doesn't expose the selected EP directly in session.
  // We infer from the handler metadata if available.
  return 'ONNX Runtime Web';
}

// --- Postprocessing ---
/**
 * Play audio samples in the browser.
 * Creates an AudioContext and plays the samples as a buffer.
 *
 * @param samples - Audio samples (Float32Array, values in [-1, 1])
 * @param sampleRate - Sample rate in Hz (default: 22050)
 * @returns Promise that resolves when playback ends
 */
function playAudio(
  samples,
  sampleRate = 22050
) {
  return new Promise((resolve) => {
    const ctx = new AudioContext({ sampleRate });
    const buffer = ctx.createBuffer(1, samples.length, sampleRate);
    buffer.copyToChannel(samples, 0);

    const source = ctx.createBufferSource();
    source.buffer = buffer;
    source.connect(ctx.destination);
    source.onended = () => resolve();
    source.start();
  });
}

/**
 * Postprocess text-to-speech model output: clamp samples for safe playback.
 *
 * @param output - Raw model output (Float32Array)
 * @returns Clamped audio samples ready for playback
 */
function postprocessAudio(output) {
  const samples = new Float32Array(output.length);
  for (let i = 0; i < output.length; i++) {
    samples[i] = Math.max(-1, Math.min(1, output[i]));
  }
  return samples;
}

// --- Application ---
const MODEL_PATH = './tts-model.onnx';
let session = null;

function updateStatus(text) {
  document.getElementById('status').textContent = text;
}

async function init() {
  updateStatus('Loading model...');
  try {
    session = await createSession(MODEL_PATH);
    updateStatus('tts-model \\u00b7 Ready');
  } catch (e) {
    updateStatus('Failed to load model');
    console.error('Model load error:', e);
  }
}

const textInput = document.getElementById('textInput');
const synthesizeBtn = document.getElementById('synthesizeBtn');

synthesizeBtn.addEventListener('click', async () => {
  const text = textInput.value.trim();
  if (!text) return;

  if (!session) {
    updateStatus('Model not loaded yet. Please wait.');
    return;
  }

  updateStatus('tts-model \\u00b7 Synthesizing...');
  const start = performance.now();

  // Simple char-to-charCode tokenization
  const tokens = new Float32Array(text.length);
  for (let i = 0; i < text.length; i++) {
    tokens[i] = text.charCodeAt(i);
  }

  const output = await runInference(session, tokens);
  const samples = postprocessAudio(output);
  await playAudio(samples);

  const elapsed = (performance.now() - start).toFixed(1);
  updateStatus('tts-model \\u00b7 ' + elapsed + 'ms \\u00b7 ' + getBackendLabel(session));
});

init();
  </script>
</body>
</html>

=== README.md ===
# tts-model — Text to Speech

Generated by [webai.js](https://github.com/ibelem/webai.js)

## Quick Start

1. Copy your model file (\`tts-model.onnx\`) into this directory
2. Start a local server: \`npx serve .\` (or any static file server)
3. Open \`index.html\` in your browser

## How It Works

1. **Preprocessing**: Image is resized to 224x224px, normalized with
   mean=[0, 0, 0] and std=[1, 1, 1], then transposed to NCHW layout.
2. **Inference**: Model runs via ONNX Runtime Web with automatic backend selection (WebNN NPU > WebNN GPU > WebGPU > WASM).
3. **Postprocessing**: Raw logits are converted to probabilities (softmax), then top-5 results are extracted.

## Configuration

| Setting | Value |
|---------|-------|
| Task | Text to Speech |
| Engine | ONNX Runtime Web |
| Backend | auto |
| Framework | html |
| Model | tts-model |
| Input | file |

## Files

- \`index.html\`
- \`README.md\`
"
`;

