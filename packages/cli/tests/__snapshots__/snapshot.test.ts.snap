}

/* VAD: speech segments */
.vad-segments {
  display: flex;
  flex-direction: column;
  gap: var(--webai-space-1);
}
.vad-segment {
  display: flex;
  justify-content: space-between;
  padding: var(--webai-space-2) var(--webai-space-3);
